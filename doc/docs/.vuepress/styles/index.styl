.air-cloud-sidebar-filter
  padding 0.75rem 1.5rem
  border-bottom 1px solid #eaecef
  background #fff

.air-cloud-sidebar-filter__select
  width 100%
  height 2.25rem
  padding 0 0.5rem
  border 1px solid #dfe2e5
  border-radius 4px
  background #fff
  color #2c3e50
  font-size 0.9rem
  outline none

.air-cloud-sidebar-filter__select:focus
  border-color $accentColor
  box-shadow 0 0 0 2px rgba(62, 175, 124, 0.15)

@media (max-width: $MQMobile)
  .air-cloud-sidebar-filter
    padding 0.75rem 1rem
